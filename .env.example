# Pollar SDK configuration
# Get your keys from https://dashboard.pollar.xyz -> Configuration -> API Keys -> Generate
#
# The PUBLISHABLE key is safe to expose in the browser (it is sent to the client).
# Use the testnet key (pub_testnet_...) for development, mainnet (pub_mainnet_...) for production.
NEXT_PUBLIC_POLLAR_PUBLISHABLE_KEY=pub_testnet_xxxxxxxxxxxxxxxxxxxx

# Stellar network the SDK talks to: "testnet" or "mainnet". Defaults to testnet.
NEXT_PUBLIC_POLLAR_NETWORK=testnet

# NOTE: A SECRET key (sec_..._) is only needed for backend/server-side calls.
# This app is fully client-side, so it is NOT required here. Never expose it to the browser.

# Soroban RPC endpoint for the Soroswap swap builder (server-side only).
# Primary (SDF, verified alive): https://soroban-testnet.stellar.org
# Note: https://rpc-testnet.stellar.org is currently unreachable (HTTP 000)
# Omit to use the primary endpoint as default.
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
